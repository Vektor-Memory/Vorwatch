# /etc/vorwatch/vorwatch.conf
# Sourced directly by the `vorwatch` script — plain shell variable
# assignments, no special syntax. Anything left unset falls back to
# vorwatch's built-in defaults.
#
# Prefer running install.sh's interactive wizard over editing this file
# by hand — it prompts for everything below and writes this file for you.

# Where baseline/alerts/blocklist/state files live.
# Default: $HOME/.vorwatch -- uncomment and change if you want it
# somewhere else.
# VORWATCH_DIR="/home/youruser/vorwatch"

# Public threat intelligence feed used to cross-reference outbound
# connections and SSH source IPs. FireHOL's level1 netset aggregates
# Spamhaus DROP, DShield, and other known-malicious ranges — free,
# no signup, no API key.
VORWATCH_BLOCKLIST_URL="https://raw.githubusercontent.com/firehol/blocklist-ipsets/master/firehol_level1.netset"

# How old the cached blocklist can get (seconds) before it's re-downloaded.
VORWATCH_BLOCKLIST_AGE_MAX=86400

# Cron schedule used by `vorwatch install`.
VORWATCH_CRON_SCHEDULE="*/15 * * * *"

# --- Optional: nginx anomaly detection tuning ---
# VORWATCH_NGINX_LOG="/var/log/nginx/access.log"
# VORWATCH_NGINX_REQ_THRESHOLD=200
# VORWATCH_NGINX_404_THRESHOLD=20
# VORWATCH_NGINX_WINDOW_LINES=3000

# --- Optional: IP reputation scoring (nginx top-5 source IPs only) ---
# Free tier at https://www.abuseipdb.com, 1000 checks/day. Leave unset
# and top-5 IPs just show as "unrated".
# VORWATCH_ABUSEIPDB_KEY=""
# VORWATCH_IP_REP_CACHE_TTL_DAYS=7

# --- Optional: email notifications via Resend (https://resend.com) ---
# Unset VORWATCH_EMAIL_TO disables email entirely (default). Urgent
# alerts (blocklist hits, file tampering, nginx attack patterns) send
# immediately; everything else lands in the scheduled digest only.
# The From address's domain must be verified in your Resend account.
# VORWATCH_EMAIL_TO="you@example.com,teammate@example.com"
# VORWATCH_EMAIL_FROM="Vorwatch <alerts@yourdomain.com>"
# VORWATCH_RESEND_API_KEY=""
# VORWATCH_EMAIL_FREQUENCY="monday"          # daily | monday
# VORWATCH_EMAIL_CRON=""                     # raw cron override, optional
# VORWATCH_EMAIL_URGENT_COOLDOWN_HOURS=4

# --- Optional: package vulnerability scanning (OSV.dev, no API key) ---
# On by default. Needs python3. Scans your installed package list in
# one batched HTTP call, cached for VULN_CACHE_TTL_HOURS.
# VORWATCH_VULN_SCAN="true"
# VORWATCH_VULN_CACHE_TTL_HOURS=24
# VORWATCH_VULN_REPORT_MAX=15
# VORWATCH_VULN_IDS_PER_PKG=8

# --- Optional: rootkit/backdoor scanning ---
# On by default, but a no-op unless chkrootkit or rkhunter is installed.
# Rate-limited to once per ROOTKIT_SCAN_HOURS regardless of check cadence.
# VORWATCH_ROOTKIT_SCAN="true"
# VORWATCH_ROOTKIT_SCAN_HOURS=24

# --- Optional: CIS-style hardening spot-checks ---
# On by default. sshd config + critical file permission checks. Only
# re-alerts when findings change, not on every check.
# VORWATCH_CIS_CHECKS="true"

# --- Optional: DNS query anomaly detection ---
# Off by default (unset). Point at a resolver log to enable first-seen
# domain tracking, the same pattern used for outbound IPs.
# VORWATCH_DNS_LOG="/var/log/dnsmasq.log"
# VORWATCH_DNS_WINDOW_LINES=2000

# --- Optional: CISA KEV cross-reference ---
# On by default. OSV.dev returns every historical CVE/USN ever filed
# against a package version, including ancient/low-severity/already-fixed
# entries -- that can mean 1000+ IDs on a fully patched box. This cross-
# references those IDs against CISA's Known Exploited Vulnerabilities
# catalog (free, no key, actively maintained) so the report can separate
# "OSV found something historical" from "this is confirmed being
# exploited in the wild right now" -- the latter is what actually
# deserves your attention.
# VORWATCH_KEV_SCAN="true"
# VORWATCH_KEV_CACHE_TTL_HOURS=24

# --- Optional: trusted outbound CIDR allowlist ---
# Sites behind a CDN/proxy generate constant "first-seen outbound IP"
# noise for connections to the CDN's own rotating edge ranges -- that's
# not suspicious, it's just infrastructure. List CIDRs/IPs here (or point
# at a URL, e.g. Cloudflare's published ranges) to silence first-seen
# alerts for known-good infrastructure. Trusted IPs are still recorded
# for later review, they just never alert.
# VORWATCH_TRUSTED_CIDRS="10.0.0.0/8,203.0.113.5"
# VORWATCH_TRUSTED_CIDRS_URL="https://www.cloudflare.com/ips-v4"
# VORWATCH_TRUSTED_CIDRS_AGE_MAX=604800

# --- Optional: known-bot annotation on nginx top-5 source IPs ---
# AbuseIPDB risk scores reflect the reputation of the IP's /24 or ASN,
# not the specific request pattern -- large cloud ranges (AWS, Azure,
# GCP) that host legitimate crawlers alongside bad actors often score
# misleadingly high. This annotates a recognized crawler name (from the
# dominant user-agent) next to the IP when one matches, so a risk-4
# GPTBot doesn't read the same as a risk-4 unknown scanner without
# checking the log yourself.
# VORWATCH_KNOWN_BOT_UA_REGEX="Googlebot|bingbot|GPTBot|ClaudeBot|..."
