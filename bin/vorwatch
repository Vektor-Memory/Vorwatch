#!/bin/bash
set -uo pipefail

VERSION="0.9.0"

CONFIG_FILE="${VORWATCH_CONFIG:-/etc/vorwatch/vorwatch.conf}"
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

DIR="${VORWATCH_DIR:-$HOME/.vorwatch}"
BASELINE="$DIR/baseline.txt"
SEEN_IPS="$DIR/seen-outbound-ips.txt"
SEEN_DOMAINS="$DIR/seen-domains.txt"
BLOCKLIST="$DIR/blocklist-cache.txt"
BLOCKLIST_URL="${VORWATCH_BLOCKLIST_URL:-https://raw.githubusercontent.com/firehol/blocklist-ipsets/master/firehol_level1.netset}"
BLOCKLIST_AGE_MAX="${VORWATCH_BLOCKLIST_AGE_MAX:-86400}"

# --- Trusted outbound CIDR allowlist (optional) ---
# Sites fronted by a CDN/proxy (Cloudflare, etc.) or that routinely call
# their own infrastructure (mail relay, API partners) generate constant
# "first-seen outbound IP" noise for connections that aren't actually
# suspicious -- CDN edge nodes rotate through huge, legitimate ranges.
# This lets you mark known-good CIDRs so first-seen alerts only fire for
# IPs genuinely outside your expected footprint. Trusted IPs are still
# recorded (so you can audit them later) but never alert.
TRUSTED_CIDRS="$DIR/trusted-cidrs.txt"
TRUSTED_CIDRS_URL="${VORWATCH_TRUSTED_CIDRS_URL:-}"
TRUSTED_CIDRS_EXTRA="${VORWATCH_TRUSTED_CIDRS:-}"
TRUSTED_CIDRS_AGE_MAX="${VORWATCH_TRUSTED_CIDRS_AGE_MAX:-604800}"
LOG="$DIR/alerts.log"
CRONLOG="$DIR/cron.log"
CRON_SCHEDULE="${VORWATCH_CRON_SCHEDULE:-*/15 * * * *}"
SEEN_IP_TTL_DAYS="${VORWATCH_SEEN_IP_TTL_DAYS:-90}"
DATE=$(date '+%Y-%m-%d %H:%M:%S %Z')

CRITICAL_FILES="${VORWATCH_CRITICAL_FILES:-/etc/ssh/sshd_config /etc/passwd /etc/shadow /etc/crontab /etc/nginx/nginx.conf $HOME/.ssh/authorized_keys}"

# --- Package vulnerability scanning (optional, no API key needed) ---
# Queries OSV.dev's free batch API with your installed package list in
# a single HTTP call (not one call per package), parsed with python3
# for correctness against nested JSON. Cached for VULN_CACHE_TTL_HOURS
# so repeat runs don't re-hit the API. Skipped entirely if python3 or
# /etc/os-release isn't available -- degrades gracefully like the
# fail2ban/docker checks already do.
VULN_SCAN="${VORWATCH_VULN_SCAN:-true}"
VULN_CACHE="$DIR/vuln-cache.txt"
VULN_CACHE_TTL_HOURS="${VORWATCH_VULN_CACHE_TTL_HOURS:-24}"
VULN_LAST_FRESH="false"

# --- CISA KEV cross-reference (optional, on by default) ---
# OSV.dev intentionally returns every historical CVE/USN ever filed
# against a package version -- including decades-old, low-severity, or
# already-patched-elsewhere entries. That's comprehensive but not
# actionable: a fully-patched box can still show 1000+ IDs. This cross-
# references the CVE IDs OSV finds against CISA's Known Exploited
# Vulnerabilities catalog -- a small, free, actively-maintained list of
# CVEs with confirmed real-world exploitation. The intersection is what
# actually deserves attention; everything else is background noise.
KEV_SCAN="${VORWATCH_KEV_SCAN:-true}"
KEV_CACHE="$DIR/kev-cache.txt"
KEV_URL="${VORWATCH_KEV_URL:-https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json}"
KEV_CACHE_TTL_HOURS="${VORWATCH_KEV_CACHE_TTL_HOURS:-24}"

# --- Rootkit / backdoor signature scanning (optional) ---
# Shells out to chkrootkit or rkhunter if either is installed, skipped
# entirely if neither is present. Rate-limited independently of the
# check cron -- a filesystem-wide scan is heavier than everything else
# here, so it runs at most once per ROOTKIT_SCAN_HOURS regardless of
# how often `vorwatch check` itself runs.
ROOTKIT_SCAN="${VORWATCH_ROOTKIT_SCAN:-true}"
ROOTKIT_STATE="$DIR/rootkit-last-scan.txt"
ROOTKIT_SCAN_HOURS="${VORWATCH_ROOTKIT_SCAN_HOURS:-24}"

# --- CIS-style hardening spot-checks (optional, on by default) ---
# Cheap config/permission checks, not a full CIS benchmark run. Only
# re-alerts when the set of findings changes, so a known, unfixed
# issue doesn't re-fire every 15 minutes forever.
CIS_CHECKS="${VORWATCH_CIS_CHECKS:-true}"

# --- DNS query anomaly detection (optional, off unless a log is set) ---
# Points at a resolver log (dnsmasq or systemd-resolved) and flags
# first-seen queried domains, the same pattern used for outbound IPs.
DNS_LOG="${VORWATCH_DNS_LOG:-}"
DNS_WINDOW_LINES="${VORWATCH_DNS_WINDOW_LINES:-2000}"

# Email notifications (optional -- everything below is a no-op if
# VORWATCH_EMAIL_TO is unset). Users add their own recipient(s) via
# VORWATCH_EMAIL_TO (comma-separated). Urgent alerts (blocklist hits,
# integrity changes, nginx scan/volume anomalies, rootkit hits) bypass
# the schedule and email immediately, subject to a per-category
# cooldown so a sustained attack doesn't flood the inbox. Everything
# else lands in the scheduled digest only.
EMAIL_TO="${VORWATCH_EMAIL_TO:-}"
EMAIL_FROM="${VORWATCH_EMAIL_FROM:-Vorwatch <alerts@yourdomain.com>}"
RESEND_EMAIL_KEY="${VORWATCH_RESEND_API_KEY:-}"
EMAIL_URGENT_COOLDOWN_HOURS="${VORWATCH_EMAIL_URGENT_COOLDOWN_HOURS:-4}"
EMAIL_URGENT_STATE="$DIR/email-urgent-state.txt"
EMAIL_FREQUENCY="${VORWATCH_EMAIL_FREQUENCY:-monday}"
case "$EMAIL_FREQUENCY" in
  daily) DEFAULT_EMAIL_CRON="0 22 * * *" ;;
  *)     DEFAULT_EMAIL_CRON="0 22 * * 0" ;;  # Sun 22:00 UTC = Mon 08:00 AEST (Brisbane, no DST)
esac
EMAIL_CRON="${VORWATCH_EMAIL_CRON:-$DEFAULT_EMAIL_CRON}"

RUN_ALERTS=""

mkdir -p "$DIR"
touch "$SEEN_IPS" "$SEEN_DOMAINS" "$LOG"

if [ -t 1 ]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_RED=$'\033[31m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_CYAN=$'\033[36m'
else
  C_RESET=''; C_BOLD=''; C_DIM=''; C_RED=''; C_GREEN=''; C_YELLOW=''; C_CYAN=''
fi

ok()    { echo "${C_GREEN}[OK]${C_RESET}   $1"; }
warn()  { echo "${C_YELLOW}[WARN]${C_RESET} $1"; }
bad()   { echo "${C_RED}[FAIL]${C_RESET} $1"; }
info()  { echo "${C_DIM}$1${C_RESET}"; }

alert() {
  echo "[$DATE] ALERT: $1" | tee -a "$LOG" >/dev/null
  RUN_ALERTS="${RUN_ALERTS}${1}
"
}

# Sends a plain-text email via Resend's REST API. No-op (returns 1) if
# EMAIL_TO or RESEND_EMAIL_KEY isn't configured. Never blocks or exits
# the script on failure -- a broken email path shouldn't take down
# monitoring itself.
send_email() {
  local subject="$1" body="$2"
  [ -n "$EMAIL_TO" ] || return 1
  [ -n "$RESEND_EMAIL_KEY" ] || return 1

  local subject_esc body_esc to_json
  subject_esc=$(echo -n "$subject" | json_escape)
  body_esc=$(echo -n "$body" | json_escape)
  to_json=$(echo "$EMAIL_TO" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^$' | awk '{printf "\"%s\",", $0}' | sed 's/,$//')
  [ -n "$to_json" ] || return 1

  curl -s -X POST https://api.resend.com/emails \
    --max-time 15 \
    -H "Authorization: Bearer $RESEND_EMAIL_KEY" \
    -H "Content-Type: application/json" \
    -d "{\"from\":\"$EMAIL_FROM\",\"to\":[$to_json],\"subject\":\"$subject_esc\",\"text\":\"$body_esc\"}" \
    >/dev/null 2>&1
}

# Scans this run's alerts for urgent categories (blocklist hits,
# integrity changes, nginx scan/volume anomalies, rootkit hits) and
# emails immediately if any are found and not in cooldown. Per-category
# cooldown (EMAIL_URGENT_COOLDOWN_HOURS) so a sustained attack sends
# one email per category per cooldown window, not one every 15 min.
# New listening ports, suspicious process trees, CIS findings, package
# vulnerabilities, and first-seen DNS queries are intentionally
# excluded here -- they go to the scheduled digest only.
check_urgent_and_notify() {
  [ -n "$EMAIL_TO" ] || return
  [ -n "$RUN_ALERTS" ] || return
  touch "$EMAIL_URGENT_STATE"

  local now to_send=""
  now=$(date +%s)

  local pair cat pattern matched last_sent age_h
  for pair in \
    "blocklist_outbound|threat blocklist" \
    "blocklist_ssh|KNOWN-BAD IP" \
    "integrity|Critical file hash" \
    "nginx_volume|High request volume" \
    "nginx_scan|Path-scanning pattern" \
    "rootkit|Rootkit scan" \
    "kev|Known Exploited Vulnerabilities"
  do
    cat="${pair%%|*}"
    pattern="${pair#*|}"
    matched=$(echo "$RUN_ALERTS" | grep -F "$pattern" || true)
    [ -n "$matched" ] || continue

    last_sent=$(grep "^$cat " "$EMAIL_URGENT_STATE" 2>/dev/null | tail -1 | awk '{print $2}')
    if [ -n "$last_sent" ]; then
      age_h=$(( (now - last_sent) / 3600 ))
      [ "$age_h" -lt "$EMAIL_URGENT_COOLDOWN_HOURS" ] && continue
    fi

    to_send="${to_send}${matched}
"
    grep -v "^$cat " "$EMAIL_URGENT_STATE" 2>/dev/null > "$EMAIL_URGENT_STATE.tmp" || true
    echo "$cat $now" >> "$EMAIL_URGENT_STATE.tmp"
    mv "$EMAIL_URGENT_STATE.tmp" "$EMAIL_URGENT_STATE"
  done

  [ -n "$to_send" ] || return
  send_email "Vorwatch URGENT - $(hostname) - possible attack activity" "$to_send"
}

refresh_blocklist() {
  if [ ! -f "$BLOCKLIST" ] || [ $(( $(date +%s) - $(stat -c %Y "$BLOCKLIST" 2>/dev/null || echo 0) )) -gt "$BLOCKLIST_AGE_MAX" ]; then
    curl -s --max-time 15 "$BLOCKLIST_URL" -o "$BLOCKLIST.tmp" 2>/dev/null
    if [ -s "$BLOCKLIST.tmp" ]; then
      grep -v '^#' "$BLOCKLIST.tmp" > "$BLOCKLIST"
      rm -f "$BLOCKLIST.tmp"
    fi
  fi
}

ip_in_blocklist() {
  local ip="$1"
  [ -f "$BLOCKLIST" ] || return 1
  awk -v target="$ip" '
    function ip2int(ip,   a,n) {
      n = split(ip, a, ".")
      if (n != 4) return -1
      return (a[1]*16777216)+(a[2]*65536)+(a[3]*256)+a[4]
    }
    BEGIN { t = ip2int(target); found = 0 }
    {
      line = $0
      sub(/#.*/, "", line)
      gsub(/^[ \t]+|[ \t]+$/, "", line)
      if (line == "") next
      if (index(line, "/") > 0) {
        split(line, parts, "/")
        net = parts[1]; bits = parts[2] + 0
      } else {
        net = line; bits = 32
      }
      n = ip2int(net)
      if (n < 0) next
      size = 2 ^ (32 - bits)
      if (t >= n && t < n + size) { found = 1; exit }
    }
    END { exit (found ? 0 : 1) }
  ' "$BLOCKLIST"
}

# Merges an optional fetched URL (e.g. Cloudflare's published IP ranges)
# with an optional inline comma-separated list into one CIDR file. The
# fetched portion is cached independently of the merge so a slow/failed
# fetch doesn't wipe out a previously-good list.
refresh_trusted_cidrs() {
  if [ -n "$TRUSTED_CIDRS_URL" ]; then
    if [ ! -f "$TRUSTED_CIDRS.fetched" ] || [ $(( $(date +%s) - $(stat -c %Y "$TRUSTED_CIDRS.fetched" 2>/dev/null || echo 0) )) -gt "$TRUSTED_CIDRS_AGE_MAX" ]; then
      curl -s --max-time 15 "$TRUSTED_CIDRS_URL" -o "$TRUSTED_CIDRS.tmp" 2>/dev/null
      if [ -s "$TRUSTED_CIDRS.tmp" ]; then
        grep -v '^#' "$TRUSTED_CIDRS.tmp" > "$TRUSTED_CIDRS.fetched"
        rm -f "$TRUSTED_CIDRS.tmp"
      fi
    fi
  fi
  {
    [ -f "$TRUSTED_CIDRS.fetched" ] && cat "$TRUSTED_CIDRS.fetched"
    [ -n "$TRUSTED_CIDRS_EXTRA" ] && echo "$TRUSTED_CIDRS_EXTRA" | tr ',' '\n' | sed 's/^ *//;s/ *$//'
    true
  } | grep -v '^$' > "$TRUSTED_CIDRS.new" 2>/dev/null
  mv "$TRUSTED_CIDRS.new" "$TRUSTED_CIDRS" 2>/dev/null
}

# Same CIDR-match logic as ip_in_blocklist, against the trusted list
# instead. Used to silence first-seen-outbound alerts for known-good
# infrastructure (your CDN, your mail relay) without disabling the
# first-seen check entirely.
ip_in_trusted() {
  local ip="$1"
  [ -s "$TRUSTED_CIDRS" ] || return 1
  awk -v target="$ip" '
    function ip2int(ip,   a,n) {
      n = split(ip, a, ".")
      if (n != 4) return -1
      return (a[1]*16777216)+(a[2]*65536)+(a[3]*256)+a[4]
    }
    BEGIN { t = ip2int(target); found = 0 }
    {
      line = $0
      sub(/#.*/, "", line)
      gsub(/^[ \t]+|[ \t]+$/, "", line)
      if (line == "") next
      if (index(line, "/") > 0) {
        split(line, parts, "/")
        net = parts[1]; bits = parts[2] + 0
      } else {
        net = line; bits = 32
      }
      n = ip2int(net)
      if (n < 0) next
      size = 2 ^ (32 - bits)
      if (t >= n && t < n + size) { found = 1; exit }
    }
    END { exit (found ? 0 : 1) }
  ' "$TRUSTED_CIDRS"
}

hash_critical_files() {
  for f in $CRITICAL_FILES; do
    if [ -r "$f" ]; then
      echo "$(sudo sha256sum "$f" 2>/dev/null || sha256sum "$f" 2>/dev/null)"
    elif sudo test -r "$f" 2>/dev/null; then
      echo "$(sudo sha256sum "$f" 2>/dev/null)"
    fi
  done
}

cmd_baseline() {
  {
    echo "# captured $DATE"
    echo "## listening_ports"
    sudo ss -tlnp 2>/dev/null | awk 'NR>1{print $4}' | sort -u
    echo "## docker_containers"
    docker ps --format '{{.Names}}' 2>/dev/null | sort -u
    echo "## known_process_names"
    ps -eo comm= | sort -u
    echo "## file_hashes"
    hash_critical_files
  } > "$BASELINE"
  ok "Baseline captured -> $BASELINE"
}

check_listening_ports() {
  [ -f "$BASELINE" ] || return
  local known current new
  known=$(sed -n '/## listening_ports/,/## docker_containers/p' "$BASELINE" | grep -v '##')
  current=$(sudo ss -tlnp 2>/dev/null | awk 'NR>1{print $4}' | sort -u)
  new=$(comm -13 <(echo "$known" | sort -u) <(echo "$current" | sort -u))
  [ -n "$new" ] && alert "New listening port(s) not in baseline: $(echo "$new" | tr '\n' ' ')"
}

check_file_integrity() {
  [ -f "$BASELINE" ] || return
  grep -q '## file_hashes' "$BASELINE" || return
  local known current changed
  known=$(sed -n '/## file_hashes/,$p' "$BASELINE" | grep -v '##')
  current=$(hash_critical_files)
  changed=$(diff <(echo "$known" | awk '{print $2, $1}' | sort) <(echo "$current" | awk '{print $2, $1}' | sort) | grep '^[<>]')
  [ -n "$changed" ] && alert "Critical file hash changed since baseline: $(echo "$changed" | tr '\n' ' | ')"
}

check_outbound_first_seen() {
  local conns
  conns=$(sudo ss -tnp state established 2>/dev/null | awk 'NR>1{print $4}' | grep -oE '^[0-9.]+' | sort -u)
  while read -r ip; do
    [ -z "$ip" ] && continue
    case "$ip" in 127.*|100.6[4-9].*|100.[7-9][0-9].*|100.1[0-1][0-9].*|10.*|169.254.*) continue ;; esac
    if ! grep -qF "$ip " "$SEEN_IPS" 2>/dev/null; then
      if ip_in_trusted "$ip"; then
        echo "$ip  first_seen=$DATE trusted=1" >> "$SEEN_IPS"
        continue
      fi
      echo "$ip  first_seen=$DATE" >> "$SEEN_IPS"
      if ip_in_blocklist "$ip"; then
        alert "Outbound connection to NEW IP $ip - this IP is on the public threat blocklist"
      else
        alert "Outbound connection to a first-seen IP: $ip (not on blocklist, just new - review)"
      fi
    fi
  done <<< "$conns"
}

prune_seen_ips() {
  [ -f "$SEEN_IPS" ] || return
  local cutoff
  cutoff=$(date -d "-${SEEN_IP_TTL_DAYS} days" '+%s' 2>/dev/null) || return
  awk -v cutoff="$cutoff" '
    {
      ts = $0; sub(/^.*first_seen=/, "", ts)
      cmd = "date -d \"" ts "\" +%s 2>/dev/null"
      cmd | getline epoch; close(cmd)
      if (epoch == "" || epoch >= cutoff) print
    }' "$SEEN_IPS" > "$SEEN_IPS.tmp" && mv "$SEEN_IPS.tmp" "$SEEN_IPS"
}

check_process_tree() {
  local watched_parents="^(nginx|node|docker-proxy|containerd)$"
  local suspicious_children="^(bash|sh|dash|python|python3|perl|nc|ncat|curl|wget)$"
  local suspicious
  suspicious=$(ps -eo pid=,ppid=,comm= 2>/dev/null | awk -v parents="$watched_parents" -v children="$suspicious_children" '
      { pid[$1]=$3; ppid[$1]=$2 }
      END {
        for (p in pid) {
          child = pid[p]; parentpid = ppid[p]
          if (child ~ children && (parentpid in pid) && pid[parentpid] ~ parents) {
            print "pid="p" comm="child" parent_pid="parentpid" parent_comm="pid[parentpid]
          }
        }
      }')
  [ -n "$suspicious" ] && alert "Suspicious process parent/child pairing detected: $(echo "$suspicious" | tr '\n' '; ')"
}

check_recent_auth_against_blocklist() {
  local recent_ips
  recent_ips=$(sudo journalctl -u ssh --since "1 hour ago" 2>/dev/null | grep -oE 'from [0-9.]+' | awk '{print $2}' | sort -u)
  while read -r ip; do
    [ -z "$ip" ] && continue
    ip_in_blocklist "$ip" && alert "SSH attempt in the last hour from a KNOWN-BAD IP (public blocklist): $ip"
  done <<< "$recent_ips"
}

# Cheap config/permission spot-checks, not a full CIS benchmark suite.
# Builds a findings string and only calls alert() when the finding set
# has changed since the last run -- an unfixed issue won't re-alert
# every 15 minutes forever, only when something changes (new problem,
# or the old one gets fixed).
check_cis_benchmarks() {
  [ "$CIS_CHECKS" = "true" ] || return
  local findings=""
  local sshd_conf="/etc/ssh/sshd_config"
  if [ -r "$sshd_conf" ] || sudo test -r "$sshd_conf" 2>/dev/null; then
    local root_login pass_auth
    root_login=$(sudo grep -iE '^[[:space:]]*PermitRootLogin' "$sshd_conf" 2>/dev/null | tail -1 | awk '{print tolower($2)}')
    pass_auth=$(sudo grep -iE '^[[:space:]]*PasswordAuthentication' "$sshd_conf" 2>/dev/null | tail -1 | awk '{print tolower($2)}')
    [ "$root_login" = "yes" ] && findings="${findings}PermitRootLogin is 'yes' in sshd_config (recommend: no or prohibit-password)
"
    [ "$pass_auth" = "yes" ] && findings="${findings}PasswordAuthentication is 'yes' in sshd_config (recommend: no, use key-only auth)
"
  fi

  local perm
  if [ -e /etc/shadow ]; then
    perm=$(stat -c '%a' /etc/shadow 2>/dev/null || sudo stat -c '%a' /etc/shadow 2>/dev/null)
    if [ -n "$perm" ] && [ "$perm" != "640" ] && [ "$perm" != "600" ]; then
      findings="${findings}/etc/shadow has permissions $perm (expected 600 or 640)
"
    fi
  fi
  if [ -e /etc/passwd ]; then
    perm=$(stat -c '%a' /etc/passwd 2>/dev/null)
    if [ -n "$perm" ] && [ "$perm" != "644" ]; then
      findings="${findings}/etc/passwd has permissions $perm (expected 644)
"
    fi
  fi

  findings="${findings%$'\n'}"

  local state_file="$DIR/cis-state.txt"
  local prev
  prev=$(cat "$state_file" 2>/dev/null || true)
  if [ "$findings" != "$prev" ]; then
    echo "$findings" > "$state_file"
    [ -n "$findings" ] && alert "CIS hardening check(s) failed: $(echo "$findings" | tr '\n' ' | ')"
  fi
}

# Shells out to chkrootkit or rkhunter if either is installed. Rate
# limited to once per ROOTKIT_SCAN_HOURS via a timestamp file, so it's
# safe to call this from every `check` run without actually scanning
# the filesystem every 15 minutes.
check_rootkit() {
  [ "$ROOTKIT_SCAN" = "true" ] || return
  touch "$ROOTKIT_STATE"
  local now last_run age_h
  now=$(date +%s)
  last_run=$(tail -1 "$ROOTKIT_STATE" 2>/dev/null)
  if [ -n "$last_run" ]; then
    age_h=$(( (now - last_run) / 3600 ))
    [ "$age_h" -lt "$ROOTKIT_SCAN_HOURS" ] && return
  fi
  echo "$now" > "$ROOTKIT_STATE"

  if command -v chkrootkit >/dev/null 2>&1; then
    local hits
    hits=$(sudo timeout 300 chkrootkit 2>/dev/null | grep "INFECTED" || true)
    [ -n "$hits" ] && alert "Rootkit scan (chkrootkit) found possible infection(s): $(echo "$hits" | tr '\n' ' | ')"
  elif command -v rkhunter >/dev/null 2>&1; then
    local hits
    hits=$(sudo timeout 300 rkhunter --check --skip-keypress --report-warnings-only 2>/dev/null || true)
    [ -n "$hits" ] && alert "Rootkit scan (rkhunter) reported warning(s): $(echo "$hits" | tr '\n' ' | ')"
  fi
}

# Tracks first-seen queried domains from a resolver log, the same
# pattern used for first-seen outbound IPs. No-op unless VORWATCH_DNS_LOG
# points at a readable log file (not every box runs a local resolver
# that logs queries).
check_dns_anomalies() {
  [ -n "$DNS_LOG" ] && [ -r "$DNS_LOG" ] || return
  local recent domains
  recent=$(tail -n "$DNS_WINDOW_LINES" "$DNS_LOG" 2>/dev/null)
  [ -n "$recent" ] || return
  domains=$(echo "$recent" | grep -oE '([a-zA-Z0-9_-]+\.)+[a-zA-Z]{2,}' | sort -u)
  while read -r d; do
    [ -z "$d" ] && continue
    if ! grep -qF "$d " "$SEEN_DOMAINS" 2>/dev/null; then
      echo "$d  first_seen=$DATE" >> "$SEEN_DOMAINS"
      alert "First-seen outbound DNS query: $d (not seen before - review if unexpected)"
    fi
  done <<< "$domains"
}

NGINX_ACCESS_LOG_FOR_CHECK="${VORWATCH_NGINX_LOG:-/var/log/nginx/access.log}"
NGINX_REQ_THRESHOLD="${VORWATCH_NGINX_REQ_THRESHOLD:-200}"
NGINX_404_THRESHOLD="${VORWATCH_NGINX_404_THRESHOLD:-20}"
NGINX_WINDOW_LINES="${VORWATCH_NGINX_WINDOW_LINES:-3000}"

# --- Known-bot annotation for nginx top source IPs (optional) ---
# AbuseIPDB risk scores reflect the reputation of the IP's /24 or ASN,
# not the specific request pattern -- large cloud ranges (AWS, Azure,
# GCP) that host legitimate crawlers alongside bad actors often score
# misleadingly high. This annotates the report's top-5 source IPs with
# a recognized bot name (from their dominant user-agent) when one
# matches, so a risk-4 GPTBot doesn't read the same as a risk-4 unknown
# scanner without more digging.
KNOWN_BOT_UA_REGEX="${VORWATCH_KNOWN_BOT_UA_REGEX:-Googlebot|bingbot|Slurp|DuckDuckBot|Baiduspider|YandexBot|GPTBot|ChatGPT-User|OAI-SearchBot|ClaudeBot|anthropic-ai|PerplexityBot|CCBot|facebookexternalhit|Twitterbot|LinkedInBot|AhrefsBot|SemrushBot|MJ12bot|PetalBot|Applebot|UptimeRobot}"

check_nginx_anomalies() {
  [ -r "$NGINX_ACCESS_LOG_FOR_CHECK" ] || return
  local recent
  recent=$(tail -n "$NGINX_WINDOW_LINES" "$NGINX_ACCESS_LOG_FOR_CHECK" 2>/dev/null)
  [ -n "$recent" ] || return

  echo "$recent" | awk '{print $1}' | sort | uniq -c | sort -rn | \
    awk -v th="$NGINX_REQ_THRESHOLD" '$1+0 >= th {print $1" "$2}' | \
  while read -r count ip; do
    [ -z "$ip" ] && continue
    alert "High request volume from $ip: $count requests in recent nginx log window (threshold $NGINX_REQ_THRESHOLD) - RECOMMENDATION: review; if malicious, ban manually (e.g. 'sudo ufw deny from $ip', or via your fail2ban nginx jail if one is configured: 'sudo fail2ban-client set <jail> banip $ip')"
  done

  echo "$recent" | awk '$9==404 {print $1}' | sort | uniq -c | sort -rn | \
    awk -v th="$NGINX_404_THRESHOLD" '$1+0 >= th {print $1" "$2}' | \
  while read -r count ip; do
    [ -z "$ip" ] && continue
    alert "Path-scanning pattern from $ip: $count distinct 404s in recent nginx log window (threshold $NGINX_404_THRESHOLD) - RECOMMENDATION: review; if malicious, ban manually (e.g. 'sudo ufw deny from $ip', or via your fail2ban nginx jail if one is configured: 'sudo fail2ban-client set <jail> banip $ip')"
  done
}

json_escape() {
  sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e ':a;N;$!ba;s/\n/\\n/g'
}

# Only alerts when a fresh scan actually ran (not a cache hit), so
# vulnerable-package alerts fire at most once per VULN_CACHE_TTL_HOURS
# instead of every 15-minute check cycle. Writes a single summary alert
# rather than one per package -- OSV.dev returns every historical
# CVE/USN against a package version, which on an older box can mean
# dozens of packages; one alert line per package would flood the log
# and the digest email. Full detail always lives in the report and the
# cache file, this just signals that a fresh scan found something.
check_vulnerabilities() {
  [ "$VULN_SCAN" = "true" ] || return
  # scan_vulnerabilities() is invoked via command substitution below, which
  # runs it in a subshell -- VULN_LAST_FRESH="true" set inside never reaches
  # this scope, so freshness is instead detected by watching whether the
  # cache file's mtime actually changed across the call.
  local cache_before cache_after
  cache_before=$(stat -c %Y "$VULN_CACHE" 2>/dev/null || echo 0)
  local findings
  findings=$(scan_vulnerabilities | filter_upgradable)
  cache_after=$(stat -c %Y "$VULN_CACHE" 2>/dev/null || echo 0)
  [ "$cache_after" != "$cache_before" ] || return
  [ -n "$findings" ] || return
  local pkg_count cve_total
  pkg_count=$(echo "$findings" | grep -c .)
  cve_total=$(echo "$findings" | awk -F': ' '{n=split($2,a,","); t+=n} END{print t+0}')
  alert "$pkg_count installed package(s) have known vulnerabilities ($cve_total total CVE/USN ID(s)) - see 'vorwatch report' for the list, or https://osv.dev"

  fetch_kev
  local kev_hits kev_count
  kev_hits=$(kev_matches "$findings")
  if [ -n "$kev_hits" ]; then
    kev_count=$(echo "$kev_hits" | grep -c .)
    alert "$kev_count installed package CVE(s) are on CISA's Known Exploited Vulnerabilities catalog (confirmed real-world exploitation): $(echo "$kev_hits" | tr '\n' ' ') - patch these first, see 'vorwatch report'"
  fi
}

cmd_check() {
  RUN_ALERTS=""
  refresh_blocklist
  refresh_trusted_cidrs
  check_listening_ports
  check_file_integrity
  check_outbound_first_seen
  check_process_tree
  check_recent_auth_against_blocklist
  check_nginx_anomalies
  check_cis_benchmarks
  check_rootkit
  check_dns_anomalies
  check_vulnerabilities
  prune_seen_ips
  check_urgent_and_notify
  return 0
}

NGINX_ACCESS_LOG="${VORWATCH_NGINX_LOG:-/var/log/nginx/access.log}"

ABUSEIPDB_KEY="${VORWATCH_ABUSEIPDB_KEY:-}"
IP_REP_CACHE="$DIR/ip-reputation-cache.txt"
IP_REP_CACHE_TTL_DAYS="${VORWATCH_IP_REP_CACHE_TTL_DAYS:-7}"

# Looks up a single IP's abuse confidence via AbuseIPDB and maps it to a
# 1-5 risk level (5 = most dangerous). File-cached per IP for
# IP_REP_CACHE_TTL_DAYS so repeat report runs against the same source IPs
# don't re-hit the API. Only ever called for the nginx top-5 source IPs
# inside `report` -- never from `check`, and never for the (much larger)
# first-seen outbound IP list. Returns "unrated" if no key is configured
# or the lookup fails; never blocks the report.
ip_reputation_score() {
  local ip="$1"
  [ -n "$ABUSEIPDB_KEY" ] || { echo "unrated"; return; }

  local now cached ts score age_days
  now=$(date +%s)
  if [ -f "$IP_REP_CACHE" ]; then
    cached=$(grep "^$ip " "$IP_REP_CACHE" 2>/dev/null | tail -1)
    if [ -n "$cached" ]; then
      ts=$(echo "$cached" | awk '{print $2}')
      score=$(echo "$cached" | awk '{print $3}')
      age_days=$(( (now - ts) / 86400 ))
      if [ "$age_days" -lt "$IP_REP_CACHE_TTL_DAYS" ]; then
        echo "$score"
        return
      fi
    fi
  fi

  local resp conf level
  resp=$(curl -s -G --max-time 8 https://api.abuseipdb.com/api/v2/check \
    --data-urlencode "ipAddress=$ip" -d maxAgeInDays=90 \
    -H "Key: $ABUSEIPDB_KEY" -H "Accept: application/json" 2>/dev/null)
  conf=$(echo "$resp" | grep -oE '"abuseConfidenceScore":[0-9]+' | grep -oE '[0-9]+$')

  if [ -z "$conf" ]; then
    echo "unrated"
    return
  fi

  if   [ "$conf" -ge 85 ]; then level=5
  elif [ "$conf" -ge 60 ]; then level=4
  elif [ "$conf" -ge 40 ]; then level=3
  elif [ "$conf" -ge 20 ]; then level=2
  else level=1
  fi

  grep -v "^$ip " "$IP_REP_CACHE" 2>/dev/null > "$IP_REP_CACHE.tmp"
  echo "$ip $now $level" >> "$IP_REP_CACHE.tmp"
  mv "$IP_REP_CACHE.tmp" "$IP_REP_CACHE"
  echo "$level"
}

# Scans installed packages against OSV.dev's free vulnerability database
# in a single batched HTTP call (not one call per package), parsed with
# python3's stdlib json module for correctness against nested response
# data -- bash regex against arbitrarily nested JSON is fragile enough
# to produce false pairings, so this leans on python3 instead like the
# rest of the script leans on coreutils. Cached for VULN_CACHE_TTL_HOURS.
# Sets VULN_LAST_FRESH=true only when an actual scan ran this call (not
# a cache hit), so callers can tell the difference.
filter_upgradable() {
  local input upgradable
  input=$(cat)
  [ -n "$input" ] || return
  upgradable=$(apt list --upgradable 2>/dev/null | cut -d/ -f1)
  if [ -z "$upgradable" ]; then
    echo "$input"
    return
  fi
  echo "$input" | awk -v upg="$upgradable" '
    BEGIN { n = split(upg, arr, "\n"); for (i = 1; i <= n; i++) up[arr[i]] = 1 }
    { split($1, f, " "); if (f[1] in up) print }
  '
}

scan_vulnerabilities() {
  [ "$VULN_SCAN" = "true" ] || return
  VULN_LAST_FRESH="false"

  local now cache_ts age_h
  now=$(date +%s)
  if [ -f "$VULN_CACHE" ]; then
    cache_ts=$(head -1 "$VULN_CACHE" 2>/dev/null | awk '{print $4}')
    if [ -n "$cache_ts" ]; then
      age_h=$(( (now - cache_ts) / 3600 ))
      if [ "$age_h" -lt "$VULN_CACHE_TTL_HOURS" ]; then
        tail -n +2 "$VULN_CACHE" 2>/dev/null
        return
      fi
    fi
  fi

  command -v python3 >/dev/null 2>&1 || return
  [ -r /etc/os-release ] || return

  local pkg_list
  if command -v dpkg-query >/dev/null 2>&1; then
    pkg_list=$(dpkg-query -W -f='${Package}\t${Version}\n' 2>/dev/null)
  elif command -v rpm >/dev/null 2>&1; then
    pkg_list=$(rpm -qa --queryformat '%{NAME}\t%{VERSION}-%{RELEASE}\n' 2>/dev/null)
  else
    return
  fi
  [ -n "$pkg_list" ] || return

  VULN_LAST_FRESH="true"
  local findings
  findings=$(echo "$pkg_list" | python3 -c '
import sys, json, urllib.request

pkgs = []
for line in sys.stdin:
    line = line.rstrip("\n")
    if not line or "\t" not in line:
        continue
    name, version = line.split("\t", 1)
    pkgs.append((name, version))

osrelease = {}
try:
    with open("/etc/os-release") as f:
        for line in f:
            if "=" in line:
                k, v = line.rstrip().split("=", 1)
                osrelease[k] = v.strip("\"")
except Exception:
    pass

os_id = osrelease.get("ID", "")
os_ver = osrelease.get("VERSION_ID", "")
eco_map = {"ubuntu": "Ubuntu:" + os_ver, "debian": "Debian:" + os_ver, "alpine": "Alpine:v" + os_ver}
ecosystem = eco_map.get(os_id)
if not ecosystem or not pkgs:
    sys.exit(0)

pkgs = pkgs[:1000]
queries = [{"package": {"name": n, "ecosystem": ecosystem}, "version": v} for n, v in pkgs]

try:
    req = urllib.request.Request(
        "https://api.osv.dev/v1/querybatch",
        data=json.dumps({"queries": queries}).encode(),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=25) as resp:
        data = json.loads(resp.read().decode())
except Exception:
    sys.exit(0)

results = data.get("results", [])
for (name, version), result in zip(pkgs, results):
    vulns = (result or {}).get("vulns", [])
    if vulns:
        ids = ",".join(v.get("id", "?") for v in vulns)
        print(name + " " + version + ": " + ids)
' 2>/dev/null)

  {
    echo "# cached at $now"
    echo "$findings"
  } > "$VULN_CACHE"

  echo "$findings"
}

# Downloads and caches CISA's Known Exploited Vulnerabilities catalog as
# a flat list of CVE IDs. Small (a few thousand entries), free, no API
# key, updated by CISA as new exploitation is confirmed. Cached for
# KEV_CACHE_TTL_HOURS like the vuln scan itself.
fetch_kev() {
  [ "$KEV_SCAN" = "true" ] || return
  local now cache_ts age_h
  now=$(date +%s)
  if [ -f "$KEV_CACHE" ]; then
    cache_ts=$(head -1 "$KEV_CACHE" 2>/dev/null | awk '{print $4}')
    if [ -n "$cache_ts" ]; then
      age_h=$(( (now - cache_ts) / 3600 ))
      [ "$age_h" -lt "$KEV_CACHE_TTL_HOURS" ] && return
    fi
  fi
  command -v python3 >/dev/null 2>&1 || return
  local resp
  resp=$(curl -s --max-time 20 "$KEV_URL" 2>/dev/null)
  [ -n "$resp" ] || return
  local ids
  ids=$(echo "$resp" | python3 -c '
import sys, json
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for v in data.get("vulnerabilities", []):
    cve = v.get("cveID")
    if cve:
        print(cve)
' 2>/dev/null)
  [ -n "$ids" ] || return
  {
    echo "# cached at $now"
    echo "$ids"
  } > "$KEV_CACHE"
}

# Extracts CVE IDs embedded in OSV findings (e.g. "UBUNTU-CVE-2024-6387"
# contains "CVE-2024-6387") and intersects them against the cached KEV
# list. Plain USN-only IDs with no embedded CVE can't be matched this
# way and are silently skipped -- that's a known limitation, not a bug.
kev_matches() {
  local findings="$1"
  [ "$KEV_SCAN" = "true" ] || return
  [ -s "$KEV_CACHE" ] || return
  echo "$findings" | grep -oE 'CVE-[0-9]{4}-[0-9]+' | sort -u | \
  while read -r cve; do
    grep -qxF "$cve" "$KEV_CACHE" 2>/dev/null && echo "$cve"
  done
}

report_fail2ban_text() {
  command -v fail2ban-client >/dev/null 2>&1 || return
  local jails
  jails=$(sudo fail2ban-client status 2>/dev/null | grep 'Jail list' | sed 's/.*://' | tr ',' '\n' | sed 's/^ *//;s/ *$//')
  [ -n "$jails" ] || return
  echo "${C_CYAN}-- fail2ban --${C_RESET}"
  while read -r jail; do
    [ -z "$jail" ] && continue
    local detail failed cur_banned tot_banned
    detail=$(sudo fail2ban-client status "$jail" 2>/dev/null)
    failed=$(echo "$detail" | grep 'Total failed' | awk -F: '{gsub(/[ \t]/,"",$2); print $2}')
    cur_banned=$(echo "$detail" | grep 'Currently banned' | awk -F: '{gsub(/[ \t]/,"",$2); print $2}')
    tot_banned=$(echo "$detail" | grep 'Total banned' | awk -F: '{gsub(/[ \t]/,"",$2); print $2}')
    printf "  %-24s total_failed=%-8s currently_banned=%-6s total_banned=%s\n" "$jail" "${failed:-0}" "${cur_banned:-0}" "${tot_banned:-0}"
  done <<< "$jails"
  echo
}

report_vitals_text() {
  echo "${C_CYAN}-- System Vitals --${C_RESET}"
  local load mem disk uptime_h
  load=$(uptime 2>/dev/null | sed 's/.*load average: //')
  mem=$(free -m 2>/dev/null | awk '/^Mem:/{printf "%dMB/%dMB used (%.0f%%)", $3, $2, ($2>0 ? $3/$2*100 : 0)}')
  disk=$(df -h / 2>/dev/null | awk 'NR==2{print $3"/"$2" used ("$5")"}')
  uptime_h=$(uptime -p 2>/dev/null || uptime 2>/dev/null | awk -F'( |,)' '{print $3, $4}')
  echo "  Load average: ${load:-unavailable}"
  echo "  Memory:       ${mem:-unavailable}"
  echo "  Disk (/):     ${disk:-unavailable}"
  echo "  Uptime:       ${uptime_h:-unavailable}"
  echo
}

report_nginx_text() {
  [ -r "$NGINX_ACCESS_LOG" ] || return
  echo "${C_CYAN}-- nginx (current log file only) --${C_RESET}"
  local total
  total=$(wc -l < "$NGINX_ACCESS_LOG" 2>/dev/null || echo 0)
  echo "  Requests logged:        $total"
  echo "  Status code breakdown:"
  awk '{print $9}' "$NGINX_ACCESS_LOG" 2>/dev/null | grep -E '^[0-9]{3}$' | sort | uniq -c | sort -rn | head -6 | \
    awk '{printf "    %-5s %s\n", $2, $1}'
  echo "  Top 5 source IPs by request count (risk 1-5, 5=critical, via AbuseIPDB):"
  awk '{print $1}' "$NGINX_ACCESS_LOG" 2>/dev/null | sort | uniq -c | sort -rn | head -5 | \
  while read -r count ip; do
    [ -z "$ip" ] && continue
    local risk bot_tag ua
    risk=$(ip_reputation_score "$ip")
    bot_tag=""
    # Split on double-quote instead of anchoring to end-of-line: some nginx
    # configs (this one included) append extra unquoted fields after the
    # user-agent (e.g. "cf_ip=..."), which breaks a $-anchored quote match.
    # In the standard combined log format the user-agent is always the 3rd
    # quoted segment (request, referer, user-agent), i.e. awk field 6 when
    # splitting on '"'.
    ua=$(grep -F "$ip " "$NGINX_ACCESS_LOG" 2>/dev/null | awk -F'"' 'NF>=6{print $6}' | sort | uniq -c | sort -rn | head -1 | sed -E 's/^ *[0-9]+ //')
    if [ -n "$ua" ] && echo "$ua" | grep -qiE "$KNOWN_BOT_UA_REGEX"; then
      bot_tag=" [bot: $(echo "$ua" | grep -ioE "$KNOWN_BOT_UA_REGEX" | head -1)]"
    fi
    printf "    %-20s %-12s [risk %s]%s\n" "$ip" "$count requests" "$risk" "$bot_tag"
  done
  echo "  Top 5 paths returning 404 (scan/probe signal):"
  awk '$9==404 {print $7}' "$NGINX_ACCESS_LOG" 2>/dev/null | sort | uniq -c | sort -rn | head -5 | \
    awk '{printf "    %-40s %s hits\n", $2, $1}'
  echo
}

report_vulnerabilities_text() {
  [ "$VULN_SCAN" = "true" ] || return
  echo "${C_CYAN}-- Package Vulnerabilities (OSV.dev, cached) --${C_RESET}"
  local findings pkg_count cve_total shown
  findings=$(scan_vulnerabilities | filter_upgradable)
  if [ -n "$findings" ]; then
    pkg_count=$(echo "$findings" | grep -c .)
    cve_total=$(echo "$findings" | awk -F': ' '{n=split($2,a,","); t+=n} END{print t+0}')
    echo "  $pkg_count package(s), $cve_total total CVE/USN ID(s) found (via OSV.dev, filtered to packages with an apt upgrade available)"
    shown="${VORWATCH_VULN_REPORT_MAX:-15}"
    local ids_shown="${VORWATCH_VULN_IDS_PER_PKG:-8}"
    echo "$findings" \
      | awk -F': ' '{n=split($2,a,","); print n"\t"$0}' \
      | sort -t$'\t' -k1,1 -rn \
      | cut -f2- \
      | head -n "$shown" \
      | awk -F': ' -v ids_shown="$ids_shown" '
          { n = split($2, a, ",")
            line = $1 ": "
            lim = (n < ids_shown ? n : ids_shown)
            for (i = 1; i <= lim; i++) { line = line a[i] (i < lim ? "," : "") }
            if (n > ids_shown) line = line " (+" (n - ids_shown) " more)"
            print line
          }' \
      | sed 's/^/  /'
    if [ "$pkg_count" -gt "$shown" ]; then
      echo "  ... and $(( pkg_count - shown )) more package(s) not shown (see $VULN_CACHE for the full list)"
    fi
    echo "  Look up any ID at: https://osv.dev/vulnerability/<ID>"

    fetch_kev
    local kev_hits kev_count
    kev_hits=$(kev_matches "$findings")
    echo
    echo "${C_CYAN}-- Actively Exploited (CISA KEV cross-reference) --${C_RESET}"
    if [ -n "$kev_hits" ]; then
      kev_count=$(echo "$kev_hits" | grep -c .)
      echo "  ${C_RED}$kev_count CVE ID(s) above are on CISA's Known Exploited Vulnerabilities catalog -- confirmed real-world exploitation, prioritize these first:${C_RESET}"
      echo "$kev_hits" | sed 's/^/    /'
      echo "  Details: https://www.cisa.gov/known-exploited-vulnerabilities-catalog"
    else
      echo "  none of the $cve_total CVE ID(s) above are on CISA's KEV list -- nothing here has confirmed real-world exploitation"
    fi
  else
    echo "  none found (or python3/os-release unavailable, or scan not yet run)"
  fi
  echo
}

report_rootkit_text() {
  [ "$ROOTKIT_SCAN" = "true" ] || return
  command -v chkrootkit >/dev/null 2>&1 || command -v rkhunter >/dev/null 2>&1 || return
  echo "${C_CYAN}-- Rootkit Scan --${C_RESET}"
  if [ -f "$ROOTKIT_STATE" ]; then
    local last_run age_h
    last_run=$(tail -1 "$ROOTKIT_STATE" 2>/dev/null)
    if [ -n "$last_run" ]; then
      age_h=$(( ($(date +%s) - last_run) / 3600 ))
      echo "  Last scan: ${age_h}h ago (runs at most every ${ROOTKIT_SCAN_HOURS}h)"
    fi
  else
    echo "  Not yet run -- next 'vorwatch check' will trigger the first scan"
  fi
  echo
}

cmd_report() {
  local range="all"
  local as_json="false"
  local as_email="false"
  while [ $# -gt 0 ]; do
    case "$1" in
      --range) range="$2"; shift 2 ;;
      --json) as_json="true"; shift ;;
      --email) as_email="true"; shift ;;
      today|24h|7d|all) range="$1"; shift ;;
      *) shift ;;
    esac
  done

  filter_log() {
    case "$range" in
      today) grep "^\[$(date '+%Y-%m-%d')" "$LOG" 2>/dev/null ;;
      24h)
        awk -v cutoff="$(date -d '24 hours ago' '+%s' 2>/dev/null)" '
          { ts = substr($0, 2, 19); cmd = "date -d \"" ts "\" +%s 2>/dev/null"; cmd | getline epoch; close(cmd); if (epoch >= cutoff) print }
        ' "$LOG" 2>/dev/null ;;
      7d)
        awk -v cutoff="$(date -d '7 days ago' '+%s' 2>/dev/null)" '
          { ts = substr($0, 2, 19); cmd = "date -d \"" ts "\" +%s 2>/dev/null"; cmd | getline epoch; close(cmd); if (epoch >= cutoff) print }
        ' "$LOG" 2>/dev/null ;;
      *) cat "$LOG" 2>/dev/null ;;
    esac
  }

  local filtered total blocklist_age_h blocklist_entries known_ips
  filtered=$(filter_log)
  total=$(echo "$filtered" | grep -c "ALERT:" || true)
  blocklist_age_h=0
  blocklist_entries=0
  [ -f "$BLOCKLIST" ] && blocklist_age_h=$(( ($(date +%s) - $(stat -c %Y "$BLOCKLIST")) / 3600 )) && blocklist_entries=$(wc -l < "$BLOCKLIST")
  known_ips=$(wc -l < "$SEEN_IPS" 2>/dev/null || echo 0)

  if [ "$as_json" = "true" ]; then
    local new_ports first_seen blocked_out sus_proc blocked_ssh
    new_ports=$(echo "$filtered" | grep -c "New listening port" || true)
    first_seen=$(echo "$filtered" | grep -c "first-seen IP:" || true)
    blocked_out=$(echo "$filtered" | grep -c "threat blocklist" || true)
    sus_proc=$(echo "$filtered" | grep -c "Suspicious process" || true)
    blocked_ssh=$(echo "$filtered" | grep -c "KNOWN-BAD IP" || true)
    local kev_json
    kev_json=$(echo "$filtered" | grep -c "Known Exploited Vulnerabilities catalog" || true)

    printf '{\n'
    printf '  "generated": "%s",\n' "$(echo -n "$DATE" | json_escape)"
    printf '  "range": "%s",\n' "$range"
    printf '  "monitor": {\n'
    printf '    "baseline_captured": %s,\n' "$([ -f "$BASELINE" ] && echo "\"$(head -1 "$BASELINE" | sed 's/# captured //' | json_escape)\"" || echo "null")"
    printf '    "blocklist_age_hours": %d,\n' "$blocklist_age_h"
    printf '    "blocklist_entries": %d,\n' "$blocklist_entries"
    printf '    "known_outbound_ips": %d\n' "$known_ips"
    printf '  },\n'
    printf '  "summary": {\n'
    printf '    "total_alerts": %d,\n' "$total"
    printf '    "new_listening_ports": %d,\n' "$new_ports"
    printf '    "first_seen_outbound_ip": %d,\n' "$first_seen"
    printf '    "blocklisted_outbound": %d,\n' "$blocked_out"
    printf '    "suspicious_proc_tree": %d,\n' "$sus_proc"
    printf '    "blocklisted_ssh_source": %d,\n' "$blocked_ssh"
    printf '    "kev_hits": %d\n' "$kev_json"
    printf '  },\n'
    printf '  "recent_alerts": [\n'
    local first=1
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      [ "$first" -eq 0 ] && printf ',\n'
      printf '    "%s"' "$(echo -n "$line" | json_escape)"
      first=0
    done < <(echo "$filtered" | tail -20)
    printf '\n  ]\n'
    printf '}\n'
    return 0
  fi

  generate_report_text() {
    echo "${C_BOLD}============================================================${C_RESET}"
    echo "${C_BOLD} Vörwatch — VPS Anomaly Detection — Text Report${C_RESET}"
    echo " Generated: $DATE"
    echo " Range: $range"
    echo "${C_BOLD}============================================================${C_RESET}"
    echo

    local hits
    hits=$(echo "$filtered" | grep -E "threat blocklist|KNOWN-BAD IP|Critical file hash|Rootkit scan|Known Exploited Vulnerabilities catalog")
    echo "${C_CYAN}-- High Priority (blocklist matches + integrity/rootkit/KEV hits) --${C_RESET}"
    if [ -n "$hits" ]; then
      echo "$hits" | sed "s/^/  ${C_RED}/;s/\$/${C_RESET}/"
    else
      echo "  none"
    fi
    echo

    echo "${C_CYAN}-- Alert Summary ($range) --${C_RESET}"
    echo "  Total alerts:           $total"
    echo "  New listening ports:    $(echo "$filtered" | grep -c "New listening port" || true)"
    echo "  Critical file changed:  $(echo "$filtered" | grep -c "Critical file hash" || true)"
    echo "  First-seen outbound IP: $(echo "$filtered" | grep -c "first-seen IP:" || true)"
    echo "  Blocklisted outbound:   $(echo "$filtered" | grep -c "threat blocklist" || true)"
    echo "  Suspicious proc tree:   $(echo "$filtered" | grep -c "Suspicious process" || true)"
    echo "  Blocklisted SSH source: $(echo "$filtered" | grep -c "KNOWN-BAD IP" || true)"
    echo "  CIS hardening findings: $(echo "$filtered" | grep -c "CIS hardening" || true)"
    echo "  Rootkit findings:       $(echo "$filtered" | grep -c "Rootkit scan" || true)"
    echo "  First-seen DNS queries: $(echo "$filtered" | grep -c "first-seen outbound DNS" || true)"
    echo "  Vulnerable packages:    $(echo "$filtered" | grep -c "known vulnerabilities" || true)"
    echo "  KEV (actively exploited): $(echo "$filtered" | grep -c "Known Exploited Vulnerabilities catalog" || true)"
    echo

    report_vitals_text
    report_fail2ban_text
    report_nginx_text
    report_vulnerabilities_text
    report_rootkit_text

    echo "${C_CYAN}-- Monitor Health --${C_RESET}"
    if [ -f "$BASELINE" ]; then
      echo "  Baseline captured:     $(head -1 "$BASELINE" | sed 's/# captured //')"
    else
      echo "  Baseline captured:     NEVER - run: vorwatch baseline"
    fi
    if [ -f "$CRONLOG" ]; then
      echo "  Last cron run (mtime): $(stat -c '%y' "$CRONLOG" 2>/dev/null | cut -d. -f1)"
    else
      echo "  Last cron run:         no cron.log found - run: vorwatch install"
    fi
    if [ -f "$BLOCKLIST" ]; then
      echo "  Blocklist age:         ${blocklist_age_h}h old, $blocklist_entries entries"
    else
      echo "  Blocklist:             not yet downloaded"
    fi
    echo "  Known outbound IPs:    $known_ips"
    echo

    echo "${C_CYAN}-- Most Recent Alerts (up to 10) --${C_RESET}"
    if [ -n "$filtered" ]; then
      echo "$filtered" | tail -10 | sed 's/^/  /'
    else
      echo "  none in this range"
    fi
    echo

    echo "${C_BOLD}============================================================${C_RESET}"
  }

  if [ "$as_email" = "true" ]; then
    local saved_reset="$C_RESET" saved_bold="$C_BOLD" saved_dim="$C_DIM" saved_red="$C_RED" saved_green="$C_GREEN" saved_yellow="$C_YELLOW" saved_cyan="$C_CYAN"
    C_RESET=''; C_BOLD=''; C_DIM=''; C_RED=''; C_GREEN=''; C_YELLOW=''; C_CYAN=''
    local email_body
    email_body=$(generate_report_text)
    C_RESET="$saved_reset"; C_BOLD="$saved_bold"; C_DIM="$saved_dim"; C_RED="$saved_red"; C_GREEN="$saved_green"; C_YELLOW="$saved_yellow"; C_CYAN="$saved_cyan"
    send_email "Vorwatch Digest - $(hostname) - $range" "$email_body"
    return 0
  fi

  generate_report_text
  return 0
}

cmd_status() {
  echo "${C_BOLD}Vörwatch v$VERSION${C_RESET} — status"
  echo
  [ -f "$BASELINE" ] && ok "Baseline captured ($(head -1 "$BASELINE" | sed 's/# captured //'))" || warn "No baseline yet — run: vorwatch baseline"
  if grep -q '## file_hashes' "$BASELINE" 2>/dev/null; then
    ok "File-integrity baseline present ($(sed -n '/## file_hashes/,$p' "$BASELINE" | grep -c . ) files watched)"
  else
    warn "No file-integrity baseline — run: vorwatch baseline (to add it)"
  fi
  if crontab -l 2>/dev/null | grep -q "vorwatch check"; then
    ok "Cron job installed ($CRON_SCHEDULE)"
  else
    warn "Cron job not installed — run: vorwatch install"
  fi
  if [ -f "$BLOCKLIST" ]; then
    local age_h=$(( ($(date +%s) - $(stat -c %Y "$BLOCKLIST")) / 3600 ))
    if [ "$age_h" -lt 25 ]; then ok "Blocklist fresh (${age_h}h old, $(wc -l < "$BLOCKLIST") entries, CIDR-aware matching)"; else warn "Blocklist stale (${age_h}h old)"; fi
  else
    warn "Blocklist not yet downloaded — run: vorwatch check"
  fi
  if [ -f /etc/logrotate.d/vorwatch ]; then
    ok "Log rotation configured"
  else
    warn "No log rotation — run install.sh again, or add /etc/logrotate.d/vorwatch manually"
  fi
  if [ "$VULN_SCAN" = "true" ]; then
    if command -v python3 >/dev/null 2>&1; then
      ok "Package vulnerability scanning enabled (OSV.dev, cached ${VULN_CACHE_TTL_HOURS}h)"
    else
      warn "Package vulnerability scanning enabled but python3 not found — scans will be skipped"
    fi
  fi
  if [ "$ROOTKIT_SCAN" = "true" ]; then
    if command -v chkrootkit >/dev/null 2>&1 || command -v rkhunter >/dev/null 2>&1; then
      ok "Rootkit scanning enabled (every ${ROOTKIT_SCAN_HOURS}h)"
    else
      info "  Rootkit scanning enabled but neither chkrootkit nor rkhunter is installed — skipped"
    fi
  fi
  if [ "$KEV_SCAN" = "true" ]; then
    if [ -s "$KEV_CACHE" ]; then
      ok "CISA KEV cross-reference enabled ($(grep -c . "$KEV_CACHE" 2>/dev/null || echo 0) entries cached)"
    else
      info "  CISA KEV cross-reference enabled but not yet fetched — runs on next 'vorwatch check' or 'report'"
    fi
  fi
  if [ -n "$TRUSTED_CIDRS_URL" ] || [ -n "$TRUSTED_CIDRS_EXTRA" ]; then
    ok "Trusted outbound CIDR allowlist configured ($(grep -c . "$TRUSTED_CIDRS" 2>/dev/null || echo 0) ranges)"
  fi
  local alert_count
  alert_count=$(wc -l < "$LOG" 2>/dev/null || echo 0)
  info "  $alert_count total alerts logged, $(wc -l < "$SEEN_IPS" 2>/dev/null || echo 0) known outbound IPs (TTL ${SEEN_IP_TTL_DAYS}d)"
  echo "  data dir: $DIR"
  echo "  config:   $CONFIG_FILE $([ -f "$CONFIG_FILE" ] || echo '(not found, using defaults)')"
}

cmd_install() {
  local self
  self=$(readlink -f "$0")
  (
    crontab -l 2>/dev/null | grep -v "vorwatch check" | grep -v "vorwatch report --range 7d --email"
    echo "$CRON_SCHEDULE $self check >> \"$CRONLOG\" 2>&1"
    if [ -n "$EMAIL_TO" ]; then
      echo "$EMAIL_CRON $self report --range 7d --email >> \"$CRONLOG\" 2>&1"
    fi
  ) | crontab -
  ok "Cron job installed: $CRON_SCHEDULE $self check"
  if [ -n "$EMAIL_TO" ]; then
    ok "Email digest scheduled: $EMAIL_CRON (frequency: $EMAIL_FREQUENCY) -> $EMAIL_TO"
  else
    info "  No VORWATCH_EMAIL_TO configured - email digest not scheduled"
  fi
  [ -f "$BASELINE" ] || { cmd_baseline; }
}

cmd_uninstall() {
  crontab -l 2>/dev/null | grep -v "vorwatch check" | grep -v "vorwatch report --range 7d --email" | crontab -
  ok "Cron job(s) removed"
}

cmd_help() {
  cat << 'HELP_EOF'
vorwatch — Vör's Watch: lightweight VPS anomaly detection

Usage:
  vorwatch baseline              capture current state as "known good"
  vorwatch check                 run all detection scenarios, log findings
  vorwatch report [--range R] [--json] [--email]
                                  text or JSON report (R = all|today|24h|7d)
                                  --email sends the text report via Resend
                                  instead of printing it
  vorwatch status                one-line health check of the monitor itself
  vorwatch install               install cron job(s) -- the check cron
                                  always installs; the email digest cron
                                  installs only if VORWATCH_EMAIL_TO is set
  vorwatch uninstall             remove cron job(s)
  vorwatch help                  this message
  vorwatch version                print version

Email config (all optional, set in /etc/vorwatch/vorwatch.conf):
  VORWATCH_EMAIL_TO                comma-separated recipient list
  VORWATCH_EMAIL_FROM              default: Vorwatch <alerts@yourdomain.com>
                                    (must be a domain verified in Resend)
  VORWATCH_RESEND_API_KEY          Resend API key
  VORWATCH_EMAIL_FREQUENCY         daily | monday (default: monday)
  VORWATCH_EMAIL_CRON              raw cron override for the digest send time
  VORWATCH_EMAIL_URGENT_COOLDOWN_HOURS
                                    min hours between repeat urgent emails
                                    of the same category (default: 4)

Additional detection layers (all optional, all on by default except DNS):
  VORWATCH_VULN_SCAN                true|false (default true) - package
                                     vulnerability scan via OSV.dev, needs
                                     python3, no API key required
  VORWATCH_VULN_CACHE_TTL_HOURS     default 24 - how often to re-scan
  VORWATCH_VULN_REPORT_MAX          default 15 - max packages shown in
                                     the report before summarizing the rest
  VORWATCH_VULN_IDS_PER_PKG         default 8 - max CVE/USN IDs shown per
                                     package line before summarizing
  VORWATCH_ROOTKIT_SCAN             true|false (default true) - uses
                                     chkrootkit or rkhunter if installed,
                                     skipped entirely if neither is present
  VORWATCH_ROOTKIT_SCAN_HOURS       default 24 - min hours between scans
  VORWATCH_CIS_CHECKS               true|false (default true) - sshd
                                     hardening + critical file permission
                                     spot-checks
  VORWATCH_DNS_LOG                  unset by default - path to a resolver
                                     log (dnsmasq/systemd-resolved) to
                                     enable first-seen DNS query tracking
  VORWATCH_DNS_WINDOW_LINES         default 2000

Noise reduction / signal quality (all optional):
  VORWATCH_KEV_SCAN                 true|false (default true) - cross-
                                     references OSV-found CVE IDs against
                                     CISA's Known Exploited Vulnerabilities
                                     catalog, so you can tell "actually
                                     exploited in the wild" apart from
                                     "OSV found something historical"
  VORWATCH_KEV_CACHE_TTL_HOURS      default 24 - how often to re-fetch
                                     the KEV catalog
  VORWATCH_TRUSTED_CIDRS            comma-separated CIDRs/IPs that should
                                     never trigger a first-seen-outbound-IP
                                     alert (e.g. your CDN's edge ranges,
                                     mail relay, or other known-good infra)
  VORWATCH_TRUSTED_CIDRS_URL        optional URL to fetch a trusted CIDR
                                     list from (e.g. Cloudflare's published
                                     ranges: https://www.cloudflare.com/ips-v4),
                                     merged with VORWATCH_TRUSTED_CIDRS and
                                     refreshed every VORWATCH_TRUSTED_CIDRS_AGE_MAX
                                     seconds (default 7 days)
  VORWATCH_TRUSTED_CIDRS_AGE_MAX    default 604800 (7 days)
  VORWATCH_KNOWN_BOT_UA_REGEX       override the built-in list of known
                                     good crawler user-agents (Googlebot,
                                     GPTBot, ClaudeBot, etc.) annotated
                                     next to nginx top-5 source IPs, so a
                                     risk score on shared cloud IP space
                                     doesn't read the same as an unknown
                                     scanner without checking the log
                                     yourself

Urgent alerts (blocklisted outbound/SSH, critical file changes, nginx
scan/volume anomalies, rootkit hits, CISA KEV matches) email immediately
regardless of schedule, subject to the per-category cooldown above.
Everything else (new ports, suspicious process trees, CIS findings,
vulnerable packages, first-seen DNS queries, routine first-seen IPs)
appears in the scheduled digest only.
HELP_EOF
}

cmd_version() {
  echo "vorwatch $VERSION"
}

case "${1:-help}" in
  baseline)  shift; cmd_baseline "$@" ;;
  check)     shift; cmd_check "$@" ;;
  report)    shift; cmd_report "$@" ;;
  status)    shift; cmd_status "$@" ;;
  install)   shift; cmd_install "$@" ;;
  uninstall) shift; cmd_uninstall "$@" ;;
  version|--version|-v) cmd_version ;;
  help|--help|-h|*) cmd_help ;;
esac