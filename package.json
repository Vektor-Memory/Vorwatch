{
  "name": "vorwatch",
  "version": "0.6.1",
  "description": "Vör's Watch — lightweight, dependency-free VPS anomaly detection: file integrity, port/process baselining, outbound IP reputation, nginx anomaly detection, optional email alerts. Recommend-only, never auto-bans.",
  "bin": {
    "vorwatch": "bin/vorwatch",
    "vorwatch-install": "install.sh"
  },
  "files": [
    "bin/vorwatch",
    "install.sh",
    "vorwatch.conf.example",
    "vorwatch.logrotate",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "linux"
  ],
  "scripts": {
    "postinstall": "chmod +x bin/vorwatch install.sh 2>/dev/null || true"
  },
  "keywords": [
    "security",
    "vps",
    "monitoring",
    "anomaly-detection",
    "intrusion-detection",
    "file-integrity",
    "sysadmin",
    "devops",
    "bash"
  ],
  "author": "Vektor Memory",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vektormemory/vorwatch.git"
  },
  "bugs": {
    "url": "https://github.com/vektormemory/vorwatch/issues"
  },
  "homepage": "https://github.com/vektormemory/vorwatch#readme",
  "engines": {
    "node": ">=0"
  }
}
